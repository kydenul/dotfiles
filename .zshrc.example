# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load 
# https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="powerlevel10k/powerlevel10k"

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
plugins=(z git extract web-search zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# Set kitty user variable when inside tmux (for conditional keybindings)
# Uses kitty remote control which is more reliable than DCS passthrough
if [[ -n "$TMUX" && -n "$KITTY_WINDOW_ID" ]]; then
    kitty @ set-user-vars in_tmux=yes 2>/dev/null
fi

# You may need to manually set your language environment
# export LANG=en_US.UTF-8
#
# Compilation flags
# export ARCHFLAGS="-arch x86_64"

# Preferred editor for local and remote sessions
# if [[ -n $SSH_CONNECTION ]]; then
#   export EDITOR='vim'
# else
#   export EDITOR='mvim'
# fi

# API Keys and Tokens
# IMPORTANT: Do NOT commit real API keys to Git! Instead, create a separate file: ~/.zsh_secrets
# Then uncomment the line below to source it:
[[ -f ~/.zsh_secrets ]] && source ~/.zsh_secrets

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ============================================================================
# Export variables
# ============================================================================
GOPATH="/Users/kyden/go"
GOBIN="$GOPATH/bin"
export PATH=$GOPATH/bin:$GOBIN:$PATH

# Java
export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"
export PATH="$PATH:$HOME/.ft"
export PATH="/opt/homebrew/opt/rustup/bin:$PATH"
export PATH="/opt/homebrew/opt/curl/bin:$PATH"

# Colima for Docker
export DOCKER_HOST="unix://${HOME}/.colima/default/docker.sock"

# ============================================================================
# Personal aliases
# ============================================================================
alias la="ls -a"
alias ll="ls -al"
alias c="clear"
alias vim="nvim"

# trans-shell
alias tsbz="trans -b :zh"
alias tsz="trans :zh"
alias tsbe="trans -b :en"
alias tse="trans :en"

# kitty ssh problem
export TERM=xterm-256color
alias kicat="kitty +kitten icat"
alias kssh="kitty +kitten ssh"
alias kdiff="kitty +kitten diff"
