{
  // -----------------------------------------------------------------
  "editor.fontSize": 16,
  "editor.inlineSuggest.enabled": true,
  "editor.smoothScrolling": true,
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontFamily": "'Maple Mono NF CN','Hack Nerd Font Mono', 'Fira Code', 'Source Code Pro'",
  "editor.lineNumbers": "relative",
  "editor.guides.bracketPairs": "active",
  "editor.rulers": [120],
  "editor.wordWrap": "on",
  "editor.renderWhitespace": "boundary",
  "editor.scrollbar.verticalScrollbarSize": 16,
  "editor.minimap.enabled": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "auto",
  "editor.unicodeHighlight.ambiguousCharacters": false,

  "window.customTitleBarVisibility": "windowed",
  "window.titleBarStyle": "custom",
  "window.commandCenter": false,
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${profileName}",
  "window.zoomLevel": 0.6,

  "workbench.panel.showLabels": false,
  "workbench.activityBar.location": "hidden",
  "workbench.colorTheme": "Gruvbox Dark Hard",
  "workbench.layoutControl.enabled": false,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.list.smoothScrolling": true,
  "workbench.colorCustomizations": {
    "statusBar.background": "#005f5f",
    "statusBar.foreground": "#e6e7e8",
    "terminal.foreground": "#839395",
    "editorCursor.foreground": "#91d696"
  },

  "terminal.integrated.enableMultiLinePasteWarning": "auto",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.inheritEnv": false,

  "files.autoSave": "off",
  "chat.commandCenter.enabled": false,

  "diffEditor.ignoreTrimWhitespace": true,

  // -----------------------------------------------------------------
  // Vim
  "extensions.experimental.affinity": { "vscodevim.vim": 1 }, // To improve performance
  "vim.leader": "<space>", // leader - prefix key
  "vim.easymotion": true,
  "vim.useSystemClipboard": true,
  "vim.replaceWithRegister": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.foldfix": true,
  "vim.hlsearch": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.color": "#a9dc7680",
  "vim.highlightedyank.duration": 500,

  // Input Method
  // `brew tap daipeihust/tap && brew install im-select`
  "vim.autoSwitchInputMethod.enable": true,
  "vim.autoSwitchInputMethod.defaultIM": "com.apple.keylayout.ABC",
  "vim.autoSwitchInputMethod.obtainIMCmd": "/opt/homebrew/bin/im-select",
  "vim.autoSwitchInputMethod.switchIMCmd": "/opt/homebrew/bin/im-select {im}",

  // 是否由vim接管ctrl+any的按键，而不是vscode
  "vim.useCtrlKeys": true,
  // 由vscode进行处理，而不是vscode-vim插件
  "vim.handleKeys": {
    "<C-s>": true,
    "<C-z>": false,
    "<C-x>": true
  },

  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["\\"],
      "commands": [{ "command": "workbench.action.splitEditorDown" }]
    },
    {
      "before": ["|"],
      "commands": [{ "command": "workbench.action.splitEditorRight" }]
    },

    // Resize window
    {
      "before": ["<C-Up>"],
      "commands": [{ "command": "workbench.action.increaseViewHeight" }]
    },
    {
      "before": ["<C-Down>"],
      "commands": [{ "command": "workbench.action.decreaseViewHeight" }]
    },
    {
      "before": ["<C-Left>"],
      "commands": [{ "command": "workbench.action.increaseViewWidth" }]
    },
    {
      "before": ["<C-Right>"],
      "commands": [{ "command": "workbench.action.decreaseViewWidth" }]
    },

    // Window navigation => Ctrl-h/j/k/l 在 group 之间跳转
    {
      "before": ["<C-h>"],
      "commands": [{ "command": "workbench.action.focusLeftGroup" }]
    },
    {
      "before": ["<C-j>"],
      "commands": [{ "command": "workbench.action.focusBelowGroup" }]
    },
    {
      "before": ["<C-k>"],
      "commands": [{ "command": "workbench.action.focusAboveGroup" }]
    },
    {
      "before": ["<C-l>"],
      "commands": [{ "command": "workbench.action.focusRightGroup" }]
    },

    // Terminal focus
    {
      "before": ["<C-t>"],
      "commands": [{ "command": "workbench.action.terminal.focus" }]
    },

    // Undo and Redo
    { "before": ["u"], "commands": [{ "command": "undo" }] },
    { "before": ["<C-r>"], "commands": [{ "command": "redo" }] },

    // ---------------------------------------------------------------
    // LSP
    // ---------------------------------------------------------------
    {
      "before": ["g", "d"],
      "commands": [{ "command": "editor.action.revealDefinition" }]
    },
    {
      "before": ["g", "D"],
      "commands": [{ "command": "editor.action.revealDeclaration" }]
    },
    {
      "before": ["g", "r"],
      "commands": [{ "command": "editor.action.goToReferences" }]
    },
    {
      "before": ["g", "i"],
      "commands": [{ "command": "editor.action.goToImplementation" }]
    },
    {
      "before": ["g", "K"],
      "commands": [{ "command": "editor.action.showHover" }]
    },
    {
      "before": ["g", "I"],
      "commands": [{ "command": "references-view.findReferences" }]
    },
    {
      "before": ["g", "O"],
      "commands": [{ "command": "editor.showCallHierarchy" }]
    },

    // // K: 优先显示诊断，否则 hover
    // { "before": ["K"], "commands": [{ "command": "editor.action.marker.next" }] },

    // Code action / Rename / Format
    {
      "before": ["leader", "c", "a"],
      "commands": [{ "command": "editor.action.quickFix" }]
    },
    {
      "before": ["leader", "r", "n"],
      "commands": [{ "command": "editor.action.rename" }]
    },
    {
      "before": ["leader", "="],
      "commands": [{ "command": "editor.action.formatDocument" }]
    },

    // Inlay hints toggle
    {
      "before": ["leader", "t", "h"],
      "commands": [{ "command": "editor.action.toggleInlayHints" }]
    },

    // ---------------------------------------------------------------
    // Line Home / End => H ^, L $
    // ---------------------------------------------------------------
    { "before": ["H"], "after": ["^"] },
    { "before": ["L"], "after": ["$"] },

    // ---------------------------------------------------------------
    // File / Buffer / Tab
    // ---------------------------------------------------------------
    // { "before": ["leader", "e"], "commands": [{ "command": "workbench.action.toggleSidebarVisibility" }] },
    {
      "before": ["leader", "e"],
      "commands": [{ "command": "workbench.explorer.fileView.focus" }]
    },

    // Zen mode
    {
      "before": ["leader", "z"],
      "commands": [
        {
          "command": "workbench.action.toggleZenMode",
          "when": "!isAuxiliaryWindowFocusedContext"
        }
      ]
    },

    // Save / Quit
    { "before": ["leader", "w"], "commands": [":w!"] },
    { "before": ["leader", "Q"], "commands": [":qa"] },
    {
      "before": ["leader", "q"],
      "commands": [{ "command": "workbench.action.closeActiveEditor" }]
    },

    // Tab 切换 / 关闭
    {
      "before": ["g", "t"],
      "commands": [{ "command": "workbench.action.nextEditor" }]
    },
    {
      "before": ["g", "T"],
      "commands": [{ "command": "workbench.action.previousEditor" }]
    },
    {
      "before": ["leader", "t", "c"],
      "commands": [{ "command": "workbench.action.closeActiveEditor" }]
    },

    // Buffer 操作
    {
      "before": ["leader", "b", "d"],
      "commands": [{ "command": "workbench.action.closeActiveEditor" }]
    },
    {
      "before": ["leader", "b", "o"],
      "commands": [{ "command": "workbench.action.closeOtherEditors" }]
    },

    // ---------------------------------------------------------------
    // No highlight
    // ---------------------------------------------------------------
    { "before": ["leader", "n", "h"], "commands": [":nohl"] },

    // ---------------------------------------------------------------
    // Pickers / Find
    // ---------------------------------------------------------------
    { "before": ["leader", "/"], "commands": [{ "command": "actions.find" }] },
    {
      "before": ["leader", "p"],
      "commands": [{ "command": "workbench.action.quickOpen" }]
    },
    {
      "before": ["leader", "s", "f"],
      "commands": [{ "command": "workbench.action.openRecent" }]
    },
    {
      "before": ["leader", "f", "g"],
      "commands": [{ "command": "workbench.action.findInFiles" }]
    },
    {
      "before": ["leader", "f", "b"],
      "commands": [{ "command": "workbench.action.showAllEditors" }]
    },
    // { "before": ["leader", "f", "d"], "commands": [{ "command": "workbench.actions.view.problems" }] },
    {
      "before": ["leader", "f", "m"],
      "commands": [{ "command": "workbench.action.gotoSymbol" }]
    },
    {
      "before": ["leader", "f", "n"],
      "commands": [{ "command": "notifications.showList" }]
    },
    // Todo
    {
      "before": ["leader", "f", "t", "d"],
      "commands": [{ "command": "todo-tree-view.focus" }]
    },

    // Diagnostics
    {
      "before": ["[", "d"],
      "commands": [{ "command": "editor.action.marker.prevInFiles" }]
    },
    {
      "before": ["]", "d"],
      "commands": [{ "command": "editor.action.marker.nextInFiles" }]
    },

    // Git
    {
      "before": ["leader", "g"],
      "commands": [{ "command": "workbench.scm.focus" }]
    },

    // Debug
    {
      "before": ["leader", "d", "u"],
      "commands": [{ "command": "workbench.view.debug" }]
    },
    {
      "before": ["leader", "d", "c"],
      "commands": [{ "command": "workbench.action.debug.continue" }]
    },
    {
      "before": ["leader", "d", "b"],
      "commands": [{ "command": "editor.debug.action.toggleBreakpoint" }]
    },
    {
      "before": ["leader", "d", "s"],
      "commands": [{ "command": "workbench.action.debug.stepOver" }]
    },
    {
      "before": ["leader", "d", "i"],
      "commands": [{ "command": "workbench.action.debug.stepInto" }]
    },
    {
      "before": ["leader", "d", "o"],
      "commands": [{ "command": "workbench.action.debug.stepOut" }]
    },
    {
      "before": ["leader", "d", "t"],
      "commands": [{ "command": "workbench.action.debug.stop" }]
    },
    {
      "before": ["leader", "d", "r"],
      "commands": [{ "command": "workbench.action.debug.restart" }]
    },
    {
      "before": ["leader", "d", "l"],
      "commands": [{ "command": "workbench.action.debug.start" }]
    },
    {
      "before": ["leader", "c", "c"],
      "commands": [{ "command": "go.debug.cursor" }]
    },

    // Terminal
    { "before": ["leader", "t"], "commands": [":terminal"] },

    // EasyMotion
    { "before": [","], "after": ["leader", "leader", "s"] },

    // AI Sidekick / Copilot Chat
    {
      "before": ["leader", "c", "k"],
      "commands": [{ "command": "workbench.action.chat.toggle" }]
    }
  ],

  "vim.insertModeKeyBindings": [
    { "before": ["j", "k"], "after": ["<Esc>"] },

    // cursor move
    { "before": ["<C-n>"], "commands": ["cursorDown"] },
    { "before": ["<C-p>"], "commands": ["cursorUp"] }
  ],

  "vim.visualModeKeyBindings": [
    // 缩进保持选择 (对齐 nvim: < <gv, > >gv)
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },

    // Visual 模式下，p 粘贴时不覆盖寄存器
    { "before": ["p"], "after": ["p", "g", "v", "y"] },

    // 行首 / 行尾
    { "before": ["H"], "after": ["^"] },
    { "before": ["L"], "after": ["$"] },

    // 上下移动选中行 (J/K 移动并 reindent)
    {
      "before": ["J"],
      "commands": [{ "command": "editor.action.moveLinesDownAction" }]
    },
    {
      "before": ["K"],
      "commands": [{ "command": "editor.action.moveLinesUpAction" }]
    },

    // Code action
    {
      "before": ["leader", "c", "a"],
      "commands": [{ "command": "editor.action.quickFix" }]
    },

    // EasyMotion
    { "before": [","], "after": ["leader", "leader", "s"] }
  ],

  // -----------------------------------------------------------------
  // Git
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "never",
  "gitlens.codeLens.enabled": false,
  "gitlens.statusBar.enabled": false,
  "gitlens.hovers.enabled": false,
  "gitlens.graph.layout": "editor",
  "gitlens.ai.model": "gemini:gemini-2.0-flash",
  "gitlens.views.commitDetails.files.layout": "tree",
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "repositories": false,
    "searchAndCompare": true,
    "launchpad": false
  },

  // -----------------------------------------------------------------
  // todo-tree settings
  "todo-tree.regex.regex": "((%|#|\"\"\"|'''|//|<!--|^\\s*\\*)\\s*($TAGS)|^\\s*- \\[( |x|X)\\])",
  "todo-tree.regex.regexCaseSensitive": true,
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.general.tags": ["TODO", "FIXME", "NOTE", "TAG", "BUG", "XXX"],
  "todo-tree.highlights.defaultHighlight": {
    "gutterIcon": true,
    "rulerLane": "right",
    "foreground": "#ffffff",
    "background": "#2e5e18",
    "iconColour": "#38ad01"
  },
  "todo-tree.highlights.customHighlight": {
    "FIXME": { "background": "#FF0000", "iconColour": "#FF0000" },
    "BUG": { "background": "#008000", "iconColour": "#008000" },
    "TAG": { "icon": "tag", "background": "#0b7c69", "iconColour": "#0b7c69" },
    "NOTE": {
      "icon": "note",
      "background": "#7675cf",
      "iconColour": "#7675cf"
    },
    "XXX": {
      "icon": "beaker",
      "background": "#FFA500",
      "iconColour": "#FFA500"
    }
  },

  // -----------------------------------------------------------------
  // Markdownlint
  // 关闭 preview 滚动的时候, Markdown 文件跟着滚动
  "markdown.preview.scrollEditorWithPreview": false,
  "markdown-preview-enhanced.previewTheme": "atom-dark.css",
  "markdown-preview-enhanced.enablePreviewZenMode": true,
  "markdownlint.config": {
    "MD010": false,
    "MD024": false,
    "MD033": false
  },

  // -----------------------------------------------------------------
  // Golang
  "gopls": { "ui.semanticTokens": true },
  "go.formatTool": "gofumpt",
  "go.formatFlags": ["-extra"],
  "go.inlayHints.parameterNames": false,
  "go.lintTool": "golangci-lint",
  "go.lintFlags": ["--fast"],
  "go.alternateTools": { "gofumpt": "gofumpt" },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },

  // -----------------------------------------------------------------
  // Clangd
  "clangd.onConfigChanged": "restart",
  "clangd.path": "/usr/bin/clangd",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build",
    "--header-insertion=never"
  ],
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },

  // -----------------------------------------------------------------
  // CMake
  "cmake.configureOnOpen": true,
  "cmake.generator": "Ninja",
  "cmake.parallelJobs": 0,

  // -----------------------------------------------------------------
  // LaTex
  "latex-workshop.latex.outDir": "%DIR%",
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "--output-directory=%OUTDIR%",
        "%DOCFILE%"
      ]
    },
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "--output-directory=%OUTDIR%",
        "%DOCFILE%"
      ]
    },
    {
      "name": "bibtex",
      "command": "bibtex",
      "args": ["%OUTDIR%/%DOCFILE%"],
      "env": { "TEXMFOUTPUT": "%OUTDIR%" }
    },
    {
      "name": "biber",
      "command": "biber",
      "args": ["%OUTDIR%/%DOCFILE%"],
      "env": { "TEXMFOUTPUT": "%OUTDIR%" }
    }
  ],
  "latex-workshop.latex.recipes": [
    { "name": "xelatex", "tools": ["xelatex"] },
    { "name": "pdflatex", "tools": ["pdflatex"] },
    {
      "name": "xe->bibtex->xe*2",
      "tools": ["xelatex", "bibtex", "xelatex", "xelatex"]
    },
    {
      "name": "xe->biber->xe*2",
      "tools": ["xelatex", "biber", "xelatex", "xelatex"]
    },
    {
      "name": "pdf->bib->pdf*2",
      "tools": ["pdflatex", "bibtex", "pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.ist",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
    "*.gz"
  ],
  "latex-workshop.latex.autoClean.run": "onFailed",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "lastUsed",
  "latex-workshop.showContextMenu": true,
  "latex-workshop.message.error.show": false,
  "latex-workshop.message.warning.show": false,

  // -----------------------------------------------------------------
  // plantuml
  "plantuml.exportOutDir": ".",
  "plantuml.exportFormat": "svg",
  "plantuml.exportSubFolder": false,

  // -----------------------------------------------------------------
  // remote SSH
  "remote.autoForwardPortsSource": "hybrid",
  "remote.SSH.remotePlatform": {
    "*.devcloud.woa.com": "linux",
    "DevCloud": "linux",
    "kydenlu-any1.devcloud.woa.com": "linux"
  },
  "codingcopilot.enableInlineChat": true,
  "codingcopilot.enableInlineChatIDEShortcutsTip": false,
  "codingcopilot.commitMessageStyle": "Auto",
  "codingcopilot.commitMessageLanguage": "en",
  "codingcopilot.toolbarOnSelection": false,
  "codingcopilot.enableAutoCompletions": true,
  "codingcopilot.enableNextEditSuggestions": true,
  "codingcopilot.generationPreference": "intelligentMode",
  "codingcopilot.selectedCompletionModel": "",
  "codingcopilot.enableCompletionLanguage": [],
  "codingcopilot.enableFloatShortcut": true,
  "codingcopilot.enableIDENotification": true,
  "go.toolsManagement.autoUpdate": true,
  "update.mode": "none",
  "diffEditor.hideUnchangedRegions.enabled": true
}
